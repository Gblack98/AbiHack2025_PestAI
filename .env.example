# ============================================================
# VARIABLES D'ENVIRONNEMENT — PestAI API
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# --- Clés API Google Gemini ---
# Plusieurs clés séparées par des virgules pour la rotation automatique
# Exemple : GEMINI_API_KEYS=AIza...,AIzb...,AIzc...
GEMINI_API_KEYS=your_gemini_api_key_1,your_gemini_api_key_2

# --- Cloudinary (stockage des images découpées) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
